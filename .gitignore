# Local job application run outputs
# Each Claude Code run writes a hashed artifact tree under runs/<run_id>/
# per docs/contracts/claude_run_directory.md. Keep the folder anchored
# in git via runs/.gitkeep, but never commit run contents.
runs/*
!runs/.gitkeep

# Local dev SQLite DB
# backend/app/db.py defaults JOBAPPLY_DATABASE_URL to sqlite:///./jobapply.db,
# so importing app.main (e.g. via uvicorn) from backend/ materializes a DB
# there. Tests use a tempfile and never write to this path.
backend/jobapply.db
/jobapply.db

# Editor / OS
.DS_Store
.idea/
.vscode/


# Claude Code local worktrees
.claude/worktrees/

# Claude Code local worktrees
.claude/worktrees/

# Claude Code local settings
.claude/settings.local.json
.claude/worktrees/

# Agent planner drafts
# scripts/agentctl.sh plan --ultraplan writes Ultraplan-ready prompt files
# under .agent_plans/. They are local working drafts and should not be
# committed; promote a plan by copying its scoped task files into
# agent_tasks/ and committing those instead. The directory is anchored in
# git via .agent_plans/.gitkeep.
.agent_plans/*
!.agent_plans/.gitkeep

# Agent work journals
# scripts/agentctl.sh work writes per-invocation journal files under
# .agentctl/journal/<timestamp>-<task-id>.md. They are local audit
# trails and should not be committed; the directory itself is anchored
# in git via .agentctl/journal/.gitkeep.
.agentctl/journal/*
!.agentctl/journal/.gitkeep

# Word stuff
*.docx
*.doc

# Local Gmail OAuth tokens (task 082)
# backend/app/gmail_client.py defaults the token path to
# candidate_context/gmail/token.json. The file holds a refresh token in
# plain text and must never be committed. The directory is created on
# first connect; the token blob itself is what we keep out of git.
candidate_context/gmail/token.json
candidate_context/gmail/*.json

# Settings-stored secrets (task 088). The Gmail OAuth client secret is
# persisted in the app DB today; these patterns are defensive in case a
# future change writes a settings file under candidate_context/settings/.
candidate_context/settings/gmail_oauth.json
candidate_context/settings/*.secret.json
